@using EmpMng.Presentations.ViewModels
@model DepartmentRegisterViewModel;
@{
    ViewData["Title"] = "部門登録変更(確認)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8">
            <table class="table table-hover">
                <tbody>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                        <td>@Html.DisplayFor(m => m.DeptName)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.Area)</td>
                        <td>
                            @(Model.Area == 1 ? "東京" : Model.Area == 2 ? "大阪" :
                      "--未選択--")
                        </td>
                    </tr>
                </tbody>
            </tbody>
        </table>

        <form asp-action="Register" asp-controller="DepartmentUpdate" method="post">
            <input type="hidden" asp-for="DeptId" />
            <input type="hidden" asp-for="DeptName" />
            <input type="hidden" asp-for="Area" />

            <p>
                <div class="text-center">
                    <button type="submit" class="btn btn-primary">変更</button>
                </div>
            </p>
        </form>
        <div class="mt-3">
            <a asp-controller="DepartmentUpdate" asp-action="Enter" class="btn btn-secondary">戻る</a>
        </div>
    </div>
</div>