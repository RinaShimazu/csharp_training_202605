@using EmpMng.Presentations.ViewModels
@model DepartmentRegisterViewModel
@{
    ViewData["Title"] = "部門登録変更(入力)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6">

            <form asp-action="LoadDepartment" asp-controller="DepartmentUpdate" method="post"
                  class="mb-4 p-3 border rounded bg-light">
                <div class="mb-2">
                    <label class="form-label font-weight-bold">変更する部門番号を入力</label>
                    <input asp-for="DeptId" class="form-control" type="number" required />
                    <span asp-validation-for="DeptId" class="text-danger"></span>

                </div>
                <button type="submit" class="btn btn-info w-100 text-white">部門データを読み込む</button>
            </form>

            <hr />

            <form asp-action="Confirm" asp-controller="DepartmentUpdate" method="post">

                <input type="hidden" asp-for="DeptId" />

                <div class="mb-3">
                    <label asp-for="DeptName" class="form-label"></label>
                    <input asp-for="DeptName" class="form-control" />
                </div>

                <div class="form-group">
                    <label>勤務地</label>
                    <select asp-for="Area" asp-items="Model.AreaList" class="form-control"></select>
                </div>
                <p>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary">確認</button>
                    </div>
                </p>
            </form>

            <div class="mt-3">
                <a asp-controller="SelectPage" asp-action="DepartmentSelect" class="btn btn-secondary">部門管理メニューに戻る</a>
            </div>
            <div>
                <p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                        トップページに戻る
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>
