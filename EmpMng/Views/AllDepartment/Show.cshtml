@model List<EmpMng.Applications.Domains.Department>
@{
    ViewData["Title"] = "部門一覧";
}

<div class="container mt-5">
    <h2>部門一覧</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>部門番号</th>
                <th>部門名</th>
                <th>勤務地</th>
            </tr>
        </thead>
        @foreach (var dept in Model)
        {
            <tr>
                <td>@dept.Id</td>
                <td>@dept.Name</td>
                <td>@(dept.Area == 1 ? "東京" : dept.Area == 2 ? "大阪" : "--未選択--")</td>
            </tr>
        }
    </tbody>
</table>
<div class="mt-3">
    <a asp-controller="SelectPage" asp-action="DepartmentSelect" class="btn btn-secondary">部門管理メニューに戻る</a>
</div>
</div>
