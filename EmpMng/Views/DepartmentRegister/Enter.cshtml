@using EmpMng.Presentations.ViewModels
@model DepartmentRegisterViewModel;
@{
    ViewData["Title"] = "部門登録(入力)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6">
            <form asp-action="Confirm" asp-controller="DepartmentRegister" method="post">
                <div class="mb-3">
                    <label asp-for="DeptName" class="form-label"></label>
                    <input asp-for="DeptName" class="form-control" />
                    <span asp-validation-for="DeptName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>勤務地</label>
                    <select asp-for="Area" asp-items="Model.AreaList" class="form-control"></select>
                    <span asp-validation-for="Area" class="text-danger"></span>
                </div>
                <p>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary">完了</button>
                    </div>
                </p>
            </form>

            <div class="mt-3">
                <a asp-controller="SelectPage" asp-action="DepartmentSelect" class="btn btn-secondary">部門管理メニューに戻る</a>
            </div>
            <div>
                <p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                        トップページに戻る
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>