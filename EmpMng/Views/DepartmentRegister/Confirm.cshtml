@using EmpMng.Presentations.ViewModels
@model DepartmentRegisterViewModel;
@{
    ViewData["Title"] = "部門登録(確認)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8">
            <table class="table table-hover">
                <tbody>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                        <td>@Html.DisplayFor(m => m.DeptName)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.Area)</td>
                        <td>
                            @(Model.Area == 1 ? "東京" : Model.Area == 2 ? "大阪" : "--未選択--")
                        </td>
                    </tr>
                </tbody>
            </table>

            <form>
                <input type="hidden" asp-for="DeptId" />
                <input type="hidden" asp-for="DeptName" />
                <input type="hidden" asp-for="Area" />
                <div class="text-center mt-4">
                    <div class="mt-3">
                        <a asp-controller="DepartmentRegister" asp-action="Enter" class="btn btn-secondary">戻る</a>
                    </div>
                </form>
                <div>
                    <p>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                            トップページに戻る
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>