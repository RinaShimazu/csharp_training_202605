@using EmpMng.Presentations.ViewModels
@model EmployeeRegisterViewModel
@{
    ViewData["Title"] = "社員登録削除(選択)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6">

            <form asp-action="LoadEmployee" asp-controller="EmployeeDelete" method="post"
                  class="mb-4 p-3 border rounded bg-light">
                <div class="mb-2">
                    <label class="form-label font-weight-bold">削除する社員番号を入力</label>
                    <input asp-for="EmpId" class="form-control" type="number" required />
                    <span asp-validation-for="EmpId" class="text-danger"></span>

                </div>
                <button type="submit" class="btn btn-info w-100 text-white">社員データを読み込む</button>
            </form>

            <hr />

            <form asp-action="Confirm" asp-controller="EmployeeDelete" method="post">

                <input type="hidden" asp-for="EmpId" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="DeptId" />
                <input type="hidden" asp-for="DeptName" />
                <input type="hidden" asp-for="Gender" />

                <table class="table table-hover">
                    <tbody>
                        <tr>
                            <td class="fw-bold">@Html.DisplayNameFor(m => m.Name)</td>
                            <td>@Html.DisplayFor(m => m.Name)</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                            <td>@Html.DisplayFor(m => m.DeptName)</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">@Html.DisplayNameFor(m => m.Gender)</td>
                            <td>
                                @(Model.Gender == 1 ? "男性" : Model.Gender == 2 ? "女性" : Model.Gender == 3 ? "その他" : "")
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="text-center mt-3">
                    <button type="submit" class="btn btn-primary">完了</button>
                </div>
            </form>

            <div class="mt-3">
                <a asp-controller="SelectPage" asp-action="EmployeeSelect" class="btn btn-secondary">社員管理メニューに戻る</a>
            </div>
            <div>
                <p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                        トップページに戻る
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>
