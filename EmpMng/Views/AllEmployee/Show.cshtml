@model List<EmpMng.Applications.Domains.Employee>
@{
    ViewData["Title"] = "社員一覧";
}

<div class="container mt-5">
    <h2>社員一覧</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>社員番号</th>
                <th>社員名</th>
                <th>所属部門</th>
                <th>性別</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.Id</td>
                    <td>@emp.Name</td>
                    <!-- ドメインモデル内のDepartmentオブジェクトから名前を表示 -->
                    <td>@(emp.Department?.Name ?? "未配属")</td>
                    <td>@emp.Gender</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="mt-3">
        <a asp-controller="SelectPage" asp-action="EmployeeSelect" class="btn btn-secondary">メニューに戻る</a>
    </div>
</div>
